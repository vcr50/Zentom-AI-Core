<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Normalized event layer for SentinelFlow. Converts incidents, integration logs, platform events, and future connectors into one revenue-continuity event model.</description>
    <enableActivities>true</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <label>Universal Event</label>
    <nameField>
        <displayFormat>UE-{000000}</displayFormat>
        <label>Universal Event Number</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Universal Events</pluralLabel>
    <sharingModel>ReadWrite</sharingModel>
    <visibility>Public</visibility>
</CustomObject>
