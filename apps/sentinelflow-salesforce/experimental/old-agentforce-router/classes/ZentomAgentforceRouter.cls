/**
 * ZentomAgentforceRouter
 * Bridge between Zentom's orchestration logic and Salesforce Agentforce.
 * Routes dynamic AI-generated actions through the AgentforceActionRegistry
 * for safe, governed execution within Salesforce trust boundaries.
 *
 * v2.0 Changes (Phase 6):
 *   - Wired to AgentforceActionRegistry for real action dispatch
 *   - Added telemetry via HealTelemetryService
 *   - Added Feature Flag gating for AGENTFORCE_DISPATCH
 *
 * @author  Tomcodex
 * @version 2.0 (Phase 6)
 */
@SuppressWarnings('PMD.ApexCRUDViolation')
public with sharing class ZentomAgentforceRouter {

    public class ExecutionRequest {
        @InvocableVariable(required=true description='The ID of the Incident to act on')
        public Id incidentId;

        @InvocableVariable(required=true description='The specific action string generated by Zentom AI')
        public String proposedAction;
    }

    /**
     * @description Invocable entry point for Agentforce Flows.
     * Routes each request through the action registry.
     */
    @InvocableMethod(label='Execute Zentom Action via Agentforce' description='Safely executes a dynamic action determined by Zentom AI within Salesforce trust boundaries')
    public static void executeAction(List<ExecutionRequest> requests) {
        if (requests == null || requests.isEmpty()) {
            return;
        }

        for (ExecutionRequest req : requests) {
            if (req.incidentId == null || String.isBlank(req.proposedAction)) {
                continue;
            }

            // -- Security Gate: CRUD/FLS enforcement --
            SecurityGate.requireReadAccess('Incident__c', new Set<String>{'Id'});

            // Dispatch through the action registry
            AgentforceActionRegistry.ActionResult registryResult =
                AgentforceActionRegistry.dispatch(req.incidentId, req.proposedAction);

            // Log the delegation into the audit trail
            AuditTrailService.log(
                req.incidentId,
                'Incident__c',
                'Agentforce Execution Complete',
                null,
                'Action: ' + req.proposedAction
                + ' | Success: ' + registryResult.success
                + ' | Detail: ' + registryResult.detail
                + ' | Duration: ' + registryResult.executionTimeMs + 'ms'
            );

            // Close the telemetry loop on the AI Decision
            HealTelemetryService.recordHealOutcome(
                req.incidentId,
                registryResult.success,
                req.proposedAction
            );
        }
    }

    /**
     * @description Called directly by SelfHealingEngine when a dynamic action is detected.
     * Routes through the full registry pipeline.
     */
    public static SelfHealingEngine.HealResult handoffToAgentforce(Id incidentId, String actionTaken) {
        // Dispatch through registry
        AgentforceActionRegistry.ActionResult registryResult =
            AgentforceActionRegistry.dispatch(incidentId, actionTaken);

        // Close the telemetry loop
        HealTelemetryService.recordHealOutcome(incidentId, registryResult.success, actionTaken);

        // Map back to SelfHealingEngine.HealResult
        SelfHealingEngine.HealResult result = new SelfHealingEngine.HealResult();
        result.incidentId  = incidentId;
        result.actionTaken = 'Agentforce: ' + actionTaken;
        result.success     = registryResult.success;
        result.message     = registryResult.detail + ' [' + registryResult.executionTimeMs + 'ms]';

        return result;
    }
}

