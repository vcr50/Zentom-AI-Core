# Copy this file to .env for local development.
# Keep real credentials, private URLs, customer data, and production values out of git.

NODE_ENV=development

# AI provider behavior
AI_PROVIDER=mock
AI_MOCK_FALLBACK=true

# Optional cloud provider key
GEMINI_API_KEY=

# Optional local provider configuration
OLLAMA_BASE_URL=
OLLAMA_MODEL=

# Quota defaults for local development
FREE_DAILY_AI_LIMIT=10
FOUNDER_DAILY_AI_LIMIT=100
