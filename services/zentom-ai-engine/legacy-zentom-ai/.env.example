# Zentom AI Environment Variables
# Copy this file to .env and fill in your values

# Database (PostgreSQL + pgvector required)
DATABASE_URL=postgresql://zentom_user:zentom_password@localhost:5432/zentom_db

# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# Ollama (Local LLM)
OLLAMA_URL=http://localhost:11434/api/generate

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# API Keys
# Replace these before exposing the service outside localhost.
ZENTOM_API_KEY_ADMIN=change-me-admin
ZENTOM_API_KEY_OPERATOR=change-me-operator
ZENTOM_API_KEY_SYSTEM=change-me-system
ZENTOM_DEFAULT_ORG_ID=org_sentinelflow_prod

# Webhook Secret
ZENTOM_WEBHOOK_SECRET=change-me-webhook-secret

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
